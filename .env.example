# Public Ollie app (installed into external workspaces)
SLACK_PUBLIC_CLIENT_ID=
SLACK_PUBLIC_CLIENT_SECRET=
SLACK_PUBLIC_SIGNING_SECRET=
SLACK_PUBLIC_STATE_SECRET=generate-a-long-random-string

# Operator app (installed only in your personal Slack)
SLACK_OPERATOR_BOT_TOKEN=xoxb-...
SLACK_OPERATOR_SIGNING_SECRET=
SLACK_OPERATOR_APP_TOKEN=xapp-...
SLACK_OPERATOR_USER_ID=U... # your Slack user id, invited to every new #ollie-xxx channel

# Postgres
DATABASE_URL=postgres://user:pass@host:5432/ollie

# Runtime
PORT=3000
PUBLIC_BASE_URL=https://ollie.yourdomain.com
NODE_ENV=development
